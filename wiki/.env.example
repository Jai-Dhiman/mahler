# Local write-side credentials for notion-wiki ingest and lint.
# Copy this file to mahler/wiki/.env and fill in real values.
# mahler/wiki/.env is gitignored; never commit it.

# Token for the mahler-wiki-write Notion integration (read+write).
NOTION_WIKI_WRITE_TOKEN=

# Database IDs copied from each Notion DB's URL.
NOTION_WIKI_SOURCES_DB_ID=
NOTION_WIKI_CONCEPTS_DB_ID=
NOTION_WIKI_LOG_DB_ID=
